{
  "name": "bomberman-web",
  "version": "1.0.0",
  "description": "2-4 player Bomberman — local couch play and online multiplayer, sharing one deterministic game engine.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "server": "node server/index.js",
    "start": "npm run build && node server/index.js",
    "preview": "vite preview",
    "test": "node server/test-engine.mjs && node server/test-sync.mjs && node server/test-online.mjs",
    "test:engine": "node server/test-engine.mjs",
    "test:sync": "node server/test-sync.mjs",
    "test:online": "node server/test-online.mjs"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  }
}
